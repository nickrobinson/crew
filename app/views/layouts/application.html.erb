<!DOCTYPE html>
<html class="h-full bg-gray-100">
  <head>
    <title>Crew</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <nav class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-between h-16">
          <div class="flex">
            <%= link_to root_path, class: "flex items-center gap-2 text-xl font-bold text-indigo-600 hover:text-indigo-700 transition-colors" do %>
              <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Three person crew silhouettes in boat -->
                <circle cx="7" cy="10" r="2" fill="currentColor"/>
                <circle cx="12" cy="10" r="2" fill="currentColor"/>
                <circle cx="17" cy="10" r="2" fill="currentColor"/>
                <!-- Boat hull -->
                <path d="M2 16 Q12 20 22 16 L20 18 Q12 21 4 18 Z" fill="currentColor"/>
                <!-- Water wave -->
                <path d="M3 21 Q7 19 12 21 Q17 23 21 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              </svg>
              <span>Crew</span>
            <% end %>
            <div class="ml-10 flex items-center space-x-4">
              <%= link_to "Projects", projects_path,
                  class: "px-3 py-2 rounded-md text-sm font-medium #{request.path == '/' || request.path == '/projects' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-500 hover:text-gray-700'}" %>
              <% if @project&.persisted? %>
                <span class="text-gray-300">|</span>
                <%= link_to @project.name, project_path(@project),
                    class: "px-3 py-2 rounded-md text-sm font-medium #{request.path == project_path(@project) ? 'bg-indigo-100 text-indigo-700' : 'text-gray-500 hover:text-gray-700'}" %>
                <%= link_to "Repositories", project_repositories_path(@project),
                    class: "px-3 py-2 rounded-md text-sm font-medium #{request.path.include?('/repositories') ? 'bg-indigo-100 text-indigo-700' : 'text-gray-500 hover:text-gray-700'}" %>
                <%= link_to "Developers", project_developers_path(@project),
                    class: "px-3 py-2 rounded-md text-sm font-medium #{request.path.include?('/developers') ? 'bg-indigo-100 text-indigo-700' : 'text-gray-500 hover:text-gray-700'}" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-md">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
