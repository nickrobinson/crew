<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-start mb-8">
    <div>
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
        <%= link_to "Projects", projects_path, class: "hover:text-gray-700" %>
        <span>/</span>
      </div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @project.name %></h1>
      <% if @project.description.present? %>
        <p class="text-gray-600 mt-2"><%= @project.description %></p>
      <% end %>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_project_path(@project), class: "inline-flex items-center px-3 py-2 border border-gray-300 rounded-md text-sm text-gray-700 bg-white hover:bg-gray-50" do %>
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        Edit
      <% end %>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-2xl font-bold text-gray-900"><%= @developer_stats[:total] %></div>
      <div class="text-sm text-gray-500">Total Developers</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-2xl font-bold text-gray-600"><%= @developer_stats[:new] %></div>
      <div class="text-sm text-gray-500">New</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-2xl font-bold text-yellow-600"><%= @developer_stats[:interesting] %></div>
      <div class="text-sm text-gray-500">Interesting</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-2xl font-bold text-blue-600"><%= @developer_stats[:contacted] %></div>
      <div class="text-sm text-gray-500">Contacted</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-2xl font-bold text-red-600"><%= @developer_stats[:not_a_fit] %></div>
      <div class="text-sm text-gray-500">Not a Fit</div>
    </div>
  </div>

  <!-- Quick Links -->
  <div class="grid md:grid-cols-2 gap-6 mb-8">
    <%= link_to project_repositories_path(@project), class: "block bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow" do %>
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-indigo-100 rounded-lg p-3">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
          </svg>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-medium text-gray-900">Repositories</h3>
          <p class="text-gray-500"><%= @project.repositories_count %> repositories tracked</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    <% end %>

    <%= link_to project_developers_path(@project), class: "block bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow" do %>
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-green-100 rounded-lg p-3">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-medium text-gray-900">Developers</h3>
          <p class="text-gray-500"><%= @developer_stats[:total] %> candidates found</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    <% end %>
  </div>

  <!-- Recent Imports -->
  <% if @recent_imports.any? %>
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">Recent Repositories</h2>
      </div>
      <ul class="divide-y divide-gray-200">
        <% @recent_imports.each do |repo| %>
          <li>
            <%= link_to project_repository_path(@project, repo), class: "block px-6 py-4 hover:bg-gray-50" do %>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium text-gray-900"><%= repo.name %></p>
                  <p class="text-sm text-gray-500"><%= repo.description&.truncate(60) || "No description" %></p>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= repo.import_status == 'imported' ? 'bg-green-100 text-green-800' :
                      repo.import_status == 'importing' ? 'bg-yellow-100 text-yellow-800' :
                      repo.import_status == 'failed' ? 'bg-red-100 text-red-800' :
                      'bg-gray-100 text-gray-800' %>">
                  <%= repo.import_status.titleize %>
                </span>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
